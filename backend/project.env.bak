# ===========================================
# Event Registration System - Environment
# ===========================================
# انسخ هذا الملف إلى project.env وضع القيم الفعلية
# Copy this file to project.env and set your values

# Server
PORT=5000

# Database (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=event_registration_db

# CORS - عنوان الـ frontend (مثلاً Live Server على port 5500)
CORS_ORIGIN=http://localhost:5500

# JWT - غيّر JWT_SECRET في الإنتاج!
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=7d

# Admin Panel
ADMIN_JWT_SECRET=your-admin-secret-key-change-in-production
ADMIN_JWT_EXPIRE=30m
ADMIN_INACTIVITY_MINUTES=15
DEFAULT_ADMIN_ID=30509251603574
DEFAULT_ADMIN_PASSWORD=Admin@12345
DEFAULT_ADMIN_NAME=Platform Administrator

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini


